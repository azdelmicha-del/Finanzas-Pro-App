# Local development environment variables (DO NOT commit real values)

# MongoDB Atlas URI
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/finanzas_pro?retryWrites=true&w=majority

# Admin access
ADMIN_USERNAME=your-admin-email@example.com
ADMIN_PASSWORD=your-strong-password

# AI providers (set at least one)
GOOGLE_AI_KEY=your-google-ai-key
OPENAI_API_KEY=your-openai-api-key
ANTHROPIC_API_KEY=your-anthropic-api-key

# Optional local override
PORT=10000
